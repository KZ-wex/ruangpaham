rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Shared primitive helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper to validate UserQuiz document
    function isValidUserQuiz(data) {
      return data.keys().hasAll(['userId', 'material', 'summary', 'quiz'])
        && data.userId == request.auth.uid
        && data.material is string && data.material.size() <= 800000
        && data.summary is string && data.summary.size() <= 200000
        && data.quiz is list && data.quiz.size() <= 50;
    }

    match /user_quizzes/{quizId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidUserQuiz(request.resource.data)
        && request.resource.data.createdAt == request.time;
      
      allow update: if (
        isSignedIn()
        && resource.data.userId == request.auth.uid
        && isValidUserQuiz(request.resource.data)
        && request.resource.data.userId == resource.data.userId // Immutable owner
        && request.resource.data.createdAt == resource.data.createdAt // Immutable createdAt
        && (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['score', 'updatedAt'])
        )
        && request.resource.data.score is number && request.resource.data.score >= 0 && request.resource.data.score <= 100
        && request.resource.data.updatedAt == request.time
      );
        
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
